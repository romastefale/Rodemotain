# Obrigatório
TELEGRAM_BOT_TOKEN=123456:token_do_bot
TIGRAO_BOT_ACCESS_USER_IDS=123456789
WEBHOOK_SECRET=troque-este-segredo

# Railway / Webhook
# BASE_URL agora é opcional no Railway quando RAILWAY_PUBLIC_DOMAIN ou RAILWAY_STATIC_URL existir.
# Defina manualmente apenas se quiser sobrescrever o domínio detectado.
# BASE_URL=https://seu-servico.up.railway.app
WEBHOOK_PATH=/telegram/webhook
RUN_POLLING=false
SET_WEBHOOK_ON_STARTUP=true

# Persistência
# No Railway, DATA_DIR pode ser omitido quando houver volume e RAILWAY_VOLUME_MOUNT_PATH.
# Se configurar manualmente, use o mesmo caminho do volume, normalmente /data.
# DATA_DIR=/data
# DATABASE_URL=sqlite:////data/moderador.sqlite3

# Opcional: Mini App para join request query/captcha
TIGRAO_JOIN_REQUEST_WEBAPP_URL=
